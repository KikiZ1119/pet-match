/* pages/adopt/adopt.wxss - 领养区样式 */
.adopt-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

/* Tab 栏 */
.tab-bar {
  position: relative;
  display: flex;
  background: #fff;
  padding: 0 30rpx;
  border-bottom: 2rpx solid var(--border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  position: relative;
  z-index: 2;
}

.tab-text {
  font-size: 30rpx;
  color: var(--text-light);
  font-weight: 500;
  transition: color 0.3s;
}

.tab-item.active .tab-text {
  color: var(--primary);
  font-weight: 600;
}

.tab-indicator {
  position: absolute;
  bottom: 0;
  height: 4rpx;
  background: var(--primary);
  border-radius: 4rpx 4rpx 0 0;
  transition: transform 0.3s ease;
  z-index: 1;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--text-light);
}

/* 列表滚动区域 */
.list-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 卡片列表 */
.card-list {
  padding: 20rpx 30rpx;
  padding-bottom: 40rpx;
}

.card-item {
  margin-bottom: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 60rpx;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-state .text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-state .sub-text {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 40rpx;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-light);
  font-size: 26rpx;
}
