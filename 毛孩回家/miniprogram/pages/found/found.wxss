/* pages/found/found.wxss - 捡到动物浏览列表页样式 */
.found-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

/* 激活的筛选条件标签 */
.active-filters {
  padding: 16rpx 30rpx;
  background: #fff;
  border-bottom: 2rpx solid var(--border);
}

.filter-chip-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  align-items: center;
}

.filter-chip {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 20rpx;
  background: var(--primary-light);
  border-radius: 30rpx;
  font-size: 24rpx;
  color: var(--primary-dark);
}

.chip-close {
  font-size: 20rpx;
  color: var(--primary);
}

.filter-clear {
  font-size: 24rpx;
  color: var(--text-light);
  padding: 8rpx 12rpx;
}

/* 加载状态 */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--text-light);
}

/* 列表滚动区域 */
.list-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 卡片列表 */
.card-list {
  padding: 20rpx 30rpx;
  padding-bottom: 120rpx;
}

.card-item {
  margin-bottom: 24rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 150rpx 60rpx;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.6;
}

.empty-state .text {
  font-size: 32rpx;
  color: var(--text-secondary);
  margin-bottom: 12rpx;
}

.empty-state .sub-text {
  font-size: 26rpx;
  color: var(--text-light);
  margin-bottom: 40rpx;
}

.publish-btn {
  width: 400rpx;
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 140rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
}

.fab .icon {
  font-size: 60rpx;
  font-weight: 300;
  line-height: 1;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-light);
  font-size: 26rpx;
}
