/* pages/upload-found/upload-found.wxss */

.page-upload-found {
  min-height: 100vh;
  padding-bottom: 60rpx;
}

.form-scroll {
  height: 100vh;
}

/* ===== 卡片通用 ===== */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 30rpx;
  margin: 20rpx 30rpx;
}

/* ===== 区域标题 ===== */
.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 2rpx solid var(--border);
}

.section-title-icon {
  font-size: 32rpx;
  margin-right: 10rpx;
}

.section-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.section-tip {
  font-size: 24rpx;
  color: var(--text-light);
  margin-left: 8rpx;
}

/* ===== 照片上传 ===== */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: var(--radius-sm);
  overflow: hidden;
}

.photo-preview {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  font-size: 24rpx;
  color: #fff;
  font-weight: 700;
}

/* ===== 表单组 ===== */
.form-group {
  margin-bottom: 28rpx;
}

.form-group:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 16rpx;
}

.form-label-optional {
  font-size: 24rpx;
  font-weight: 400;
  color: var(--text-light);
}

.tag-desc {
  font-size: 22rpx;
  color: var(--text-light);
}

/* ===== 地点选择 ===== */
.location-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 30rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  background: #fafafa;
}

.location-info {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.location-texts {
  display: flex;
  flex-direction: column;
  margin-left: 12rpx;
  min-width: 0;
}

.location-name {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-address {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.location-placeholder {
  display: flex;
  align-items: center;
  flex: 1;
}

.location-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.location-text {
  font-size: 28rpx;
  color: var(--text-light);
}

.location-arrow {
  font-size: 36rpx;
  color: var(--text-light);
  font-weight: 600;
  margin-left: 16rpx;
}

/* ===== 描述文本域 ===== */
.desc-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 24rpx 30rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
  line-height: 1.6;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

/* ===== 提交区域 ===== */
.submit-section {
  padding: 40rpx 30rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.submit-section .btn-primary {
  width: 100%;
  padding: 26rpx 0;
}

.submit-tip {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 20rpx;
  text-align: center;
}
