.detail-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: var(--bg-page);
}

.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 6rpx solid var(--primary-light);
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 20rpx;
  font-size: 28rpx;
  color: var(--text-light);
}

.detail-scroll {
  flex: 1;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.swiper-section {
  position: relative;
  width: 100%;
  height: 600rpx;
  overflow: hidden;
}

.image-swiper {
  width: 100%;
  height: 100%;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.status-badge {
  position: absolute;
  top: 30rpx;
  left: 30rpx;
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  font-size: 24rpx;
  color: #fff;
  font-weight: 600;
  background: rgba(0, 0, 0, 0.5);
}

.status-badge.searching {
  background: rgba(255, 152, 0, 0.85);
}

.status-badge.matching {
  background: rgba(33, 150, 243, 0.85);
}

.image-count {
  position: absolute;
  bottom: 30rpx;
  right: 30rpx;
  padding: 8rpx 20rpx;
  background: rgba(0, 0, 0, 0.4);
  border-radius: 24rpx;
  font-size: 22rpx;
  color: #fff;
}

.section {
  background: #fff;
  margin: 16rpx 30rpx;
  border-radius: var(--radius);
  padding: 30rpx;
  box-shadow: var(--shadow);
}

.section-header {
  margin-bottom: 20rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.info-header {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.animal-type-icon {
  font-size: 48rpx;
}

.animal-type-text {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.tag-section {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  background: var(--bg-page);
  border-radius: 30rpx;
  font-size: 26rpx;
}

.tag-label {
  color: var(--text-light);
}

.tag-value {
  color: var(--text-primary);
  font-weight: 600;
}

.location-content {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
}

.location-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.location-detail {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.map-btn {
  margin-top: 16rpx;
  display: inline-flex;
  align-items: center;
  gap: 8rpx;
  padding: 14rpx 32rpx;
  background: var(--primary-light);
  border-radius: 40rpx;
}

.map-btn-text {
  font-size: 26rpx;
  color: var(--primary-dark);
  font-weight: 600;
}

.time-section {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.time-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.time-label {
  font-size: 26rpx;
  color: var(--text-light);
}

.time-value {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.desc-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
}

.contact-section {
  margin-bottom: 120rpx;
}

.contact-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid var(--border);
}

.contact-row:last-child {
  border-bottom: none;
}

.contact-label {
  font-size: 28rpx;
  color: var(--text-light);
  width: 80rpx;
}

.contact-value {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 600;
}

.copy-btn {
  padding: 6rpx 20rpx;
  background: var(--primary-light);
  border-radius: 24rpx;
  font-size: 24rpx;
  color: var(--primary-dark);
}

.contact-note {
  margin-top: 12rpx;
  font-size: 22rpx;
  color: var(--text-light);
  text-align: center;
}

.bottom-spacer {
  height: 160rpx;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  background: #fff;
  border-top: 2rpx solid var(--border);
  padding: 16rpx 30rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom, 0rpx));
  gap: 20rpx;
}

.bar-action {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  border-radius: 50rpx;
  font-size: 28rpx;
  font-weight: 600;
  height: 90rpx;
}

.bar-share {
  flex: 0 0 160rpx;
  background: var(--bg-page);
  color: var(--text-primary);
}

.bar-match {
  flex: 1;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.action-icon,
.match-icon {
  font-size: 32rpx;
}
