/* components/classify-bar/classify-bar.wxss */
.classify-bar {
  background: #fff;
  padding: 20rpx 30rpx 0;
}

.search-section {
  margin-bottom: 20rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 50rpx;
  padding: 20rpx 30rpx;
}

.search-icon {
  font-size: 32rpx;
  margin-right: 12rpx;
}

.search-placeholder {
  color: #999;
  font-size: 28rpx;
}

.filter-scroll {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
}

.filter-tab {
  display: inline-flex;
  align-items: center;
  padding: 12rpx 32rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: #f5f5f5;
  color: #666;
}

.filter-tab.active {
  background: #E8F5E9;
  color: #4CAF50;
  font-weight: 600;
}

.filter-bar {
  display: flex;
  gap: 20rpx;
  padding: 16rpx 0;
  border-top: 2rpx solid #f0f0f0;
}

.filter-item {
  display: flex;
  align-items: center;
  gap: 6rpx;
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
}

.filter-item.active {
  color: #4CAF50;
  font-weight: 600;
}

.filter-item .arrow {
  font-size: 20rpx;
}

.filter-panel {
  padding: 20rpx 0;
  border-top: 2rpx solid #f0f0f0;
  animation: slideDown 0.2s ease;
}

.filter-panel.hidden {
  display: none;
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-10rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.filter-group {
  margin-bottom: 24rpx;
}

.filter-group-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.filter-group .tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.filter-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 20rpx;
}

.btn-reset {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 40rpx;
  border: 2rpx solid #ddd;
  font-size: 28rpx;
  color: #666;
}

.btn-confirm {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 40rpx;
  background: #4CAF50;
  font-size: 28rpx;
  color: #fff;
}
