.comment-box {
  background: #fff;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 16rpx 30rpx;
}

.comment-header {
  margin-bottom: 24rpx;
}

.comment-title {
  font-size: 28rpx;
  font-weight: 700;
  color: #333;
}

.comment-item {
  display: flex;
  gap: 16rpx;
  padding: 20rpx 0;
  border-bottom: 2rpx solid #f5f5f5;
}

.comment-avatar {
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #E8F5E9;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 22rpx;
  color: #4CAF50;
  font-weight: 600;
}

.comment-content {
  flex: 1;
  min-width: 0;
}

.comment-body {
  margin-bottom: 8rpx;
}

.comment-text {
  font-size: 26rpx;
  color: #333;
  line-height: 1.5;
}

.comment-footer {
  display: flex;
  gap: 20rpx;
}

.comment-time {
  font-size: 22rpx;
  color: #999;
}

.comment-empty {
  text-align: center;
  padding: 40rpx 0;
}

.empty-text {
  font-size: 26rpx;
  color: #ccc;
}

.comment-input-area {
  display: flex;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 2rpx solid #f0f0f0;
}

.comment-input {
  flex: 1;
  height: 64rpx;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 0 24rpx;
  font-size: 26rpx;
}

.comment-submit {
  height: 64rpx;
  line-height: 64rpx;
  background: #4CAF50;
  color: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  padding: 0 30rpx;
  border: none;
}

.comment-submit[disabled] {
  background: #ccc;
}
