/* components/animal-card/animal-card.wxss */
.animal-card {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
  margin-bottom: 24rpx;
}

.card-media {
  position: relative;
  width: 100%;
  height: 360rpx;
  overflow: hidden;
}

.card-image {
  width: 100%;
  height: 100%;
}

.card-badges {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  display: flex;
  gap: 10rpx;
}

.badge {
  padding: 6rpx 18rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
  color: #fff;
  font-weight: 500;
}

.badge-cat {
  background: linear-gradient(135deg, #FF9800, #F57C00);
}

.badge-dog {
  background: linear-gradient(135deg, #2196F3, #1976D2);
}

.badge-status {
  background: rgba(0,0,0,0.5);
}

.badge-adopt {
  background: linear-gradient(135deg, #E91E63, #C2185B);
}

.card-match-rate {
  position: absolute;
  bottom: 16rpx;
  right: 16rpx;
  background: rgba(76, 175, 80, 0.9);
  padding: 8rpx 20rpx;
  border-radius: 24rpx;
}

.match-text {
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
}

.card-body {
  padding: 20rpx;
}

.card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  font-size: 22rpx;
}

.tag-color {
  background: #FFF3E0;
  color: #E65100;
}

.tag-size {
  background: #E3F2FD;
  color: #1565C0;
}

.tag-gender {
  background: #F3E5F5;
  color: #7B1FA2;
}

.card-location, .card-time {
  display: flex;
  align-items: center;
  gap: 6rpx;
  margin-bottom: 8rpx;
}

.card-location .icon, .card-time .icon {
  font-size: 24rpx;
}

.card-location .text, .card-time .text {
  font-size: 24rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-desc {
  margin-top: 8rpx;
}

.card-desc .text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}
