/* app.wxss - 全局样式 */

/* 主题色 */
page {
  --primary: #4CAF50;
  --primary-dark: #388E3C;
  --primary-light: #C8E6C9;
  --danger: #F44336;
  --warning: #FF9800;
  --info: #2196F3;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-light: #999999;
  --bg-page: #f5f5f5;
  --bg-card: #ffffff;
  --border: #eeeeee;
  --shadow: 0 2px 8px rgba(0,0,0,0.08);
  --radius: 12px;
  --radius-sm: 8px;

  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: var(--bg-page);
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

/* 通用容器 */
.container {
  padding: 30rpx;
}

/* 卡片样式 */
.card {
  background: var(--bg-card);
  border-radius: var(--radius);
  box-shadow: var(--shadow);
  padding: 30rpx;
  margin-bottom: 30rpx;
}

/* 按钮样式 */
.btn-primary {
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  transition: all 0.3s;
  box-shadow: 0 4px 12px rgba(76, 175, 80, 0.3);
}

.btn-primary:active {
  transform: scale(0.97);
  box-shadow: 0 2px 6px rgba(76, 175, 80, 0.2);
}

.btn-secondary {
  background: #fff;
  color: var(--primary);
  border: 2rpx solid var(--primary);
  border-radius: 50rpx;
  padding: 22rpx 58rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
}

.btn-danger {
  background: linear-gradient(135deg, var(--danger), #D32F2F);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 60rpx;
  font-size: 32rpx;
  font-weight: 600;
  text-align: center;
  box-shadow: 0 4px 12px rgba(244, 67, 54, 0.3);
}

/* 输入框样式 */
.input-group {
  margin-bottom: 30rpx;
}

.input-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
  display: block;
}

.input-field {
  width: 100%;
  padding: 24rpx 30rpx;
  border: 2rpx solid var(--border);
  border-radius: var(--radius-sm);
  font-size: 28rpx;
  background: #fafafa;
  box-sizing: border-box;
}

.input-field:focus {
  border-color: var(--primary);
  background: #fff;
}

/* 标签选择 */
.tag-group {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.tag {
  padding: 12rpx 28rpx;
  border-radius: 40rpx;
  font-size: 26rpx;
  background: #f0f0f0;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.tag.active {
  background: var(--primary-light);
  color: var(--primary-dark);
  border-color: var(--primary);
  font-weight: 600;
}

/* 图片上传 */
.upload-area {
  width: 200rpx;
  height: 200rpx;
  border: 4rpx dashed var(--border);
  border-radius: var(--radius-sm);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fafafa;
}

.upload-area .icon {
  font-size: 60rpx;
}

.upload-area .text {
  font-size: 24rpx;
  color: var(--text-light);
  margin-top: 10rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 40rpx;
}

.empty-state .icon {
  font-size: 120rpx;
  margin-bottom: 30rpx;
  opacity: 0.5;
}

.empty-state .text {
  font-size: 30rpx;
  color: var(--text-light);
  text-align: center;
  line-height: 1.6;
}

/* 加载更多 */
.load-more {
  text-align: center;
  padding: 30rpx;
  color: var(--text-light);
  font-size: 26rpx;
}

/* 标签栏标题 */
.section-title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  padding-left: 16rpx;
  border-left: 8rpx solid var(--primary);
}

/* 浮动按钮 */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: 120rpx;
  width: 110rpx;
  height: 110rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, var(--primary), var(--primary-dark));
  color: #fff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.4);
  z-index: 100;
}

.fab .icon {
  font-size: 50rpx;
}
